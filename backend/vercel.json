{
  "version": 2,
  "builds": [
    {
      "src": "vercel_bootstrap.py",
      "use": "@vercel/python@2.11.4",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.9",
        "installCommand": "pip install -r requirements-vercel.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/vercel_bootstrap.py"
    },
    {
      "src": "/(.*)",
      "dest": "/vercel_bootstrap.py"
    }
  ]
}
