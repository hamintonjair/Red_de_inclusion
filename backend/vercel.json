{
  "version": 2,
  "builds": [
    {
      "src": "vercel_bootstrap.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "pythonVersion": "3.9",
        "includeFiles": [
          "app/**/*",
          "config.py",
          "*.py"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/vercel_bootstrap.py"
    }
  ]
}
