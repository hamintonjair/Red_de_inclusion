{
  "builds": [
    {
      "src": "backend/vercel_bootstrap.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "pythonVersion": "3.9"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/vercel_bootstrap.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
